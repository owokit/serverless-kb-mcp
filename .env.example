# 运行时与部署辅助环境变量示例。
# 复制为 `.env` 后可用于本地调试；真实密钥请保持为空或自行注入。

# 全局运行时元数据。
AWS_REGION=
AWS_DEFAULT_REGION=
POWERTOOLS_SERVICE_NAME=serverless-mcp-service
METRICS_NAMESPACE=McpKnowledgeS3Vectors
SERVERLESS_MCP_PIPELINE_CONFIG_PATH=pipeline-config.json

# 对象状态与提取编排。
OBJECT_STATE_TABLE=
EXECUTION_STATE_TABLE=
MANIFEST_INDEX_TABLE=
MANIFEST_BUCKET=
MANIFEST_PREFIX=
STEP_FUNCTIONS_STATE_MACHINE_ARN=
EMBED_QUEUE_URL=
EMBEDDING_PROJECTION_STATE_TABLE=

# 向量存储。
VECTOR_BUCKET_NAME=
VECTOR_INDEX_NAME=

# Paddle OCR 配置。
PADDLE_OCR_API_BASE_URL=https://paddleocr.aistudio-app.com/api/v2/ocr/jobs
PADDLE_OCR_API_TOKEN=
PADDLE_OCR_MODEL=PaddleOCR-VL-1.5
PADDLE_OCR_POLL_INTERVAL_SECONDS=10
PADDLE_OCR_MAX_POLL_ATTEMPTS=180
PADDLE_OCR_HTTP_TIMEOUT_SECONDS=60
PADDLE_OCR_STATUS_TIMEOUT_SECONDS=10
PADDLE_OCR_ALLOWED_HOSTS=*

# Embedding / provider 配置。
EMBEDDING_PROFILES_JSON=[{"profile_id":"openai-text-small","provider":"openai","model":"text-embedding-3-small","dimension":1536,"vector_bucket_name":"mcp-doc-pipeline-prod-s3-vectors","vector_index_name":"openai-text-embedding-3-small-1536","supported_content_kinds":["text"],"enabled":true,"enable_write":true,"enable_query":true},{"profile_id":"gemini-default","provider":"gemini","model":"gemini-embedding-2-preview","dimension":3072,"vector_bucket_name":"mcp-doc-pipeline-prod-s3-vectors","vector_index_name":"google-gemini-embedding-2-preview-3072","supported_content_kinds":["text","image"],"enabled":false,"enable_write":true,"enable_query":true}]
GEMINI_API_KEY=
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/
GEMINI_EMBEDDING_MODEL=gemini-embedding-2-preview
GEMINI_HTTP_TIMEOUT_SECONDS=120
OPENAI_API_KEY=
OPENAI_API_BASE_URL=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_HTTP_TIMEOUT_SECONDS=120
FAIL_ON_JOB_ERROR=true

# 查询与 CloudFront 分发。
QUERY_TENANT_CLAIM=tenant_id
REMOTE_MCP_DEFAULT_TENANT_ID=lookup
QUERY_MAX_TOP_K=20
QUERY_MAX_NEIGHBOR_EXPAND=2
QUERY_PROFILE_TIMEOUT_SECONDS=15
CLOUDFRONT_DISTRIBUTION_DOMAIN=
CLOUDFRONT_KEY_PAIR_ID=
CLOUDFRONT_PRIVATE_KEY_PEM=
CLOUDFRONT_PRIVATE_KEY_SECRET_ARN=
CLOUDFRONT_URL_TTL_SECONDS=900

# 部署辅助配置。
S3_LAMBDA_BUCKET_NAME=
S3_BUCKET_NAME=
S3_PREFIX=
